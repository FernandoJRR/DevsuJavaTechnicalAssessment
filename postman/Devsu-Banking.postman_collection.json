    { "key": "cliente_jose_id",      "value": "",                      "type": "string" },
    { "key": "cliente_marianela_id", "value": "",                      "type": "string" },
    { "key": "cliente_juan_id",      "value": "",                      "type": "string" },
    { "key": "fecha_inicio",         "value": "2025-01-01",            "type": "string" },
    { "key": "fecha_fin",            "value": "2030-12-31",            "type": "string" },
    { "key": "movimiento_id",        "value": "",                      "type": "string" }
  ],
